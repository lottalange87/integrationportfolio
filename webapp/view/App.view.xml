<mvc:View
    controllerName="integrationportfolio.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <App id="app">
        <pages>
            <Page id="mainPage" showHeader="false">

                <!-- ── Top bar ──────────────────────────────────────────── -->
                <customHeader>
                    <Bar design="Header">
                        <contentLeft>
                            <Title text="Integration Portfolio" titleStyle="H4"/>
                        </contentLeft>
                        <contentMiddle>
                            <Title text="Service Offerings" titleStyle="H5"/>
                        </contentMiddle>
                        <contentRight>
                            <Button
                                id="btnAddOffering"
                                text="Add Offering"
                                type="Emphasized"
                                icon="sap-icon://add"
                                press="onAddOffering"/>
                        </contentRight>
                    </Bar>
                </customHeader>

                <content>

                    <!-- ── Intro ──────────────────────────────────────────── -->
                    <VBox class="sapUiMediumMarginBeginEnd sapUiSmallMarginTopBottom">
                        <Text
                            text="Define and sequence the service offerings in your integration portfolio. Cards are displayed left → right in execution order. Use ◀ ▶ to reorder."
                            class="sapUiTinyMarginBottom"/>
                        <MessageStrip
                            id="infoStrip"
                            text="Mockup — data is in-memory only. Add offerings with the button above."
                            type="Information"
                            showIcon="true"
                            showCloseButton="false"/>
                    </VBox>

                    <!-- ── Card flow container (populated by controller) ─── -->
                    <ScrollContainer
                        horizontal="true"
                        vertical="false"
                        width="100%"
                        height="auto">
                        <HBox
                            id="offeringsFlow"
                            alignItems="Center"
                            wrap="NoWrap"
                            class="sapUiMediumMarginBeginEnd sapUiSmallMarginTopBottom offeringsFlowBox"/>
                    </ScrollContainer>

                </content>
            </Page>
        </pages>
    </App>

</mvc:View>
